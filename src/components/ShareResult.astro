---
// Keeps the current calculator inputs mirrored into the URL query string and
// offers a "copy link" button. Decoupled from any single calculator's types
// via CustomEvents, namespaced per calculator via the `calculator` prop so
// multiple calculator pages can each use this component without cross-talk:
//
//   window.dispatchEvent(new CustomEvent(`${namespace}:inputs-changed`, { detail: inputs }))
//     -> this component re-encodes `inputs` into the URL (history.replaceState)
//
//   on load, this component reads the URL and dispatches:
//     new CustomEvent(`${namespace}:restore-inputs`, { detail: decodedInputs })
//     -> the calculator page listens for this to pre-fill its form
//
//   The restore value is also retained on window.__pendingRestore[namespace] so
//   the calculator page can pick it up even if its listener registers after
//   this dispatch fires (module script order isn't guaranteed to survive a
//   future DOM reorder).
export interface Props {
  calculator?: 'roof' | 'gutter' | 'metalroof' | 'siding' | 'window';
}

const { calculator = 'roof' } = Astro.props;
---

<div class="flex flex-wrap items-center gap-3" data-share-result data-calculator={calculator}>
  <button
    type="button"
    id="share-result-button"
    class="rounded-full border border-hairline bg-canvas px-4 py-2 text-sm font-medium text-ink hover:bg-canvas-soft focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-link"
  >
    Share Result
  </button>
  <span id="share-result-status" class="text-sm text-success" aria-live="polite"></span>
</div>

<script>
  import { encodeInputs as encodeRoofInputs, decodeInputs as decodeRoofInputs } from '../lib/calculator';
  import { encodeGutterInputs, decodeGutterInputs } from '../lib/gutterCalculator';
  import { encodeMetalRoofInputs, decodeMetalRoofInputs } from '../lib/metalRoofCalculator';
  import { encodeSidingInputs, decodeSidingInputs } from '../lib/sidingCalculator';
  import { encodeWindowInputs, decodeWindowInputs } from '../lib/windowCalculator';

  const CALCULATORS = {
    roof: {
      namespace: 'roofcalc',
      encode: encodeRoofInputs,
      decode: decodeRoofInputs,
      restoreKeys: ['material', 'sqft', 'mode'],
    },
    gutter: {
      namespace: 'guttercalc',
      encode: encodeGutterInputs,
      decode: decodeGutterInputs,
      restoreKeys: ['material', 'lf', 'mode'],
    },
    metalroof: {
      namespace: 'metalroofcalc',
      encode: encodeMetalRoofInputs,
      decode: decodeMetalRoofInputs,
      restoreKeys: ['system', 'sqft', 'mode'],
    },
    siding: {
      namespace: 'sidingcalc',
      encode: encodeSidingInputs,
      decode: decodeSidingInputs,
      restoreKeys: ['material', 'wall', 'mode'],
    },
    window: {
      namespace: 'windowcalc',
      encode: encodeWindowInputs,
      decode: decodeWindowInputs,
      restoreKeys: ['type', 'frame', 'n'],
    },
  } as const;

  const container = document.querySelector<HTMLElement>('[data-share-result]');
  const calculatorKey = (container?.dataset.calculator as keyof typeof CALCULATORS) ?? 'roof';
  const { namespace, encode, decode, restoreKeys } = CALCULATORS[calculatorKey];

  const button = document.getElementById('share-result-button');
  const status = document.getElementById('share-result-status');

  window.addEventListener(`${namespace}:inputs-changed`, (event) => {
    const inputs = (event as CustomEvent).detail;
    const params = encode(inputs as never);
    const newUrl = `${window.location.pathname}?${params.toString()}`;
    window.history.replaceState(null, '', newUrl);
  });

  button?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(window.location.href);
    if (status) status.textContent = 'Link copied!';
    window.setTimeout(() => {
      if (status) status.textContent = '';
    }, 2000);
  });

  const sp = new URLSearchParams(window.location.search);
  if (restoreKeys.some((key) => sp.has(key))) {
    const restoredInputs = decode(sp as never);
    (window as unknown as { __pendingRestore?: Record<string, unknown> }).__pendingRestore ??= {};
    (window as unknown as { __pendingRestore: Record<string, unknown> }).__pendingRestore[namespace] = restoredInputs;
    window.dispatchEvent(new CustomEvent(`${namespace}:restore-inputs`, { detail: restoredInputs }));
  }
</script>
