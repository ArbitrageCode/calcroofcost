---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BLOG_POSTS } from '../../data/blogPosts';
import { buildGraph, breadcrumbNode } from '../../lib/schema';

const title = 'Roofing Cost Blog | CalcRoofCost.com';
const description = 'Research-backed articles on roof replacement cost, materials, and timing decisions.';

const jsonLd = buildGraph([
  breadcrumbNode(Astro.site!, [
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog/' },
  ]),
]);
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="text-3xl font-semibold tracking-tight text-ink">Roofing Cost Blog</h1>
    <p class="mt-4 text-body">
      Research-backed articles on roof replacement cost, materials, and repair-vs-replace timing
      &mdash; built to pair with the <a href="/" class="text-link underline hover:text-link-deep">roof replacement cost calculator</a>.
    </p>

    <ul class="mt-10 space-y-8">
      {BLOG_POSTS.map((post) => (
        <li class="border-b border-hairline pb-8">
          <a href={`/blog/${post.slug}/`} class="text-xl font-semibold text-ink hover:text-link">
            {post.title}
          </a>
          <p class="mt-2 text-sm text-mute">{post.datePublished}</p>
          <p class="mt-2 text-body">{post.description}</p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
