---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildGraph, organizationNode, breadcrumbNode } from '../lib/schema';

const title = 'Terms of Use | CalcRoofCost.com';
const description = 'Terms governing use of the calculators, content, and estimates on CalcRoofCost.com.';
const LAST_UPDATED = 'July 13, 2026';

const jsonLd = buildGraph([
  organizationNode(Astro.site!),
  breadcrumbNode(Astro.site!, [
    { name: 'Home', path: '/' },
    { name: 'Terms of Use', path: '/terms/' },
  ]),
]);
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="mx-auto max-w-2xl px-4 py-16 sm:px-6">
    <h1 class="text-3xl font-semibold tracking-tight text-ink">Terms of Use</h1>
    <p class="mt-2 text-sm text-mute">Last updated: {LAST_UPDATED}</p>

    <h2 class="mt-8 text-lg font-semibold text-ink">Estimates Are Informational Only</h2>
    <p class="mt-2 text-body">
      Every calculator, rate, and figure on CalcRoofCost.com is provided for general informational
      and planning purposes only. Estimates are based on published industry cost ranges and generic
      rate assumptions; they are not a quote, bid, or appraisal, and they do not account for
      site-specific conditions such as roof complexity, local permitting requirements, material
      availability, or contractor-specific pricing. Always obtain a written, itemized quote from a
      licensed contractor before making a purchasing decision.
    </p>

    <h2 class="mt-8 text-lg font-semibold text-ink">No Professional Advice</h2>
    <p class="mt-2 text-body">
      Content on this site, including editorial articles and FAQ answers, does not constitute
      construction, engineering, insurance, or legal advice. Consult a licensed professional for
      guidance specific to your property.
    </p>

    <h2 class="mt-8 text-lg font-semibold text-ink">Acceptable Use</h2>
    <p class="mt-2 text-body">
      You may use this site&rsquo;s calculators and content for personal and business planning
      purposes. You may not use automated means to scrape, bulk-extract, or overload or disrupt the
      site.
    </p>
    <p class="mt-2 text-body">
      You may quote, cite, and reproduce our figures, tables, and methodology for editorial,
      journalistic, or research use, with attribution and a link back to the source page on
      CalcRoofCost.com. This permission covers individual figures and tables copied by hand or
      through the site&rsquo;s own citation tools; it does not cover bulk automated extraction of the
      site&rsquo;s underlying rate data, which remains covered by the anti-scraping restriction
      above.
    </p>

    <h2 class="mt-8 text-lg font-semibold text-ink">No Warranty</h2>
    <p class="mt-2 text-body">
      This site is provided &ldquo;as is&rdquo; without warranties of any kind, express or implied,
      including accuracy or fitness for a particular purpose. We are not liable for decisions made
      based on estimates generated by this site.
    </p>

    <h2 class="mt-8 text-lg font-semibold text-ink">Changes to These Terms</h2>
    <p class="mt-2 text-body">
      We may revise these terms at any time. Continued use of the site after changes are posted
      constitutes acceptance of the updated terms.
    </p>

    <h2 class="mt-8 text-lg font-semibold text-ink">Contact</h2>
    <p class="mt-2 text-body">
      Questions about these terms can be sent to the address on our <a href="/contact/" class="text-link underline hover:text-link-deep">Contact page</a>.
    </p>
  </article>
</BaseLayout>
